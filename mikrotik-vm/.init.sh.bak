# Aktifkan IP Forwarding
sudo sysctl -w net.ipv4.ip_forward=1

# Buat rule NAT (Masquerade) agar MikroTik bisa tembus internet via Wi-Fi
# (Ganti iptables dengan nftables jika distro kamu murni pakai nftables)
sudo iptables -t nat -A POSTROUTING -o wlp4s0 -j MASQUERADE

# Buat default route di tabel 100 yang mengarah ke internet asli
sudo ip route add default via 192.168.61.145 dev wlp4s0 table 100

# Tambahkan rule: Jika source IP adalah ether1 MikroTik, gunakan tabel 100
sudo ip rule add from 172.90.90.10/24 table 100

# Hapus default route lama yang mengarah langsung ke wlp4s0
sudo ip route del default

# Tambahkan default route baru yang mengarah ke MikroTik ether2
sudo ip route add default via 172.95.95.10 dev mikrotik2
